# Dependencies
node_modules/
*/node_modules/

# Build output
dist/
*/dist/
build/
coverage/
.vite/

# Local environment
.env
.env.local
.env.*.local

# Runtime uploads and generated files
uploads/*
!uploads/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Prisma and database scratch files
*.db
*.db-journal

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Local release/build target. Keep the folder marker.
target/*
!target/README.md
!target/RELEASE.md
!target/.gitkeep
